{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write",
    "llm.complete"
  ],
  "required_executas": [
    {
      "tool_id": "notes-summary",
      "min_version": "1.0.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the Mini Notes app open. Use the notes-summary Executa when the user asks to summarize notes in this app.",
  "user_message_prefix_template": "[Mini Notes] {user_message}",
  "tags": [
    "notes",
    "productivity",
    "local-tool"
  ],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "entry": "index.html",
        "min_size": {
          "w": 360,
          "h": 480
        },
        "default_size": {
          "w": 480,
          "h": 640
        },
        "max_size": {
          "w": 720,
          "h": 960
        },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": [
        "notes-summary"
      ],
      "chat": [],
      "artifact": [],
      "llm": [
        "complete"
      ],
      "fs": [],
      "storage": [
        "get",
        "set"
      ],
      "prefs": [],
      "window": []
    },
    "csp_overrides": {
      "img-src": [
        "'self'",
        "data:",
        "blob:"
      ],
      "font-src": [
        "'self'",
        "data:"
      ],
      "style-src": [
        "'self'"
      ],
      "script-src": [
        "'self'"
      ]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [],
    "seed_storage": {},
    "user_id": 1
  }
}
